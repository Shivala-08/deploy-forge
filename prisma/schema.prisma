generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  email         String?   @unique
  name          String?
  image         String?
  emailVerified DateTime?
  githubId      String?   @unique
  githubToken   String?
  createdAt     DateTime  @default(now())
  sites         Site[]
  accounts      Account[]
  sessions      Session[]
}

model Site {
  id             String       @id @default(cuid())
  siteId         String       @unique  // slug used in URL + public/sites/{siteId}/
  name           String
  repoFullName   String       // "username/repo"
  repoBranch     String       @default("main")
  buildCommand   String       @default("npm run build")
  outputDir      String       @default("dist")
  framework      String?      // "nextjs" | "vite" | "react" | "static"
  liveUrl        String?      // deployforge.vercel.app/sites/{siteId}
  userId         String
  user           User         @relation(fields: [userId], references: [id])
  deployments    Deployment[]
  queueEntries   DeployQueue[]
  parentSiteId   String?           // enables sub-mesh topology in V2
  parent         Site?   @relation("SiteMesh", fields: [parentSiteId], references: [id])
  children       Site[]  @relation("SiteMesh")
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

model Deployment {
  id               String    @id @default(cuid())
  workflowRunId    String?   // GitHub Actions run ID for status polling
  status           String    // "QUEUED" | "BUILDING" | "READY" | "ERROR"
  commitSha        String?
  commitMessage    String?
  errorMessage     String?
  siteId           String
  site             Site      @relation(fields: [siteId], references: [id], onDelete: Cascade)
  triggeredAt      DateTime  @default(now())
  completedAt      DateTime?
  callbackToken    String?   // unique per deployment, invalidated after use
  previousCommitSha String?  // SHA before this deployment, enables rollback
  meshSizeMb       Int?      // total public/sites/ size at time of deployment
  queueEntry       DeployQueue?
}

model DeployQueue {
  id           String   @id @default(cuid())
  siteId       String
  deploymentId String   @unique
  status       String   @default("WAITING") // "WAITING" | "PROCESSING" | "DONE"
  position     Int
  createdAt    DateTime @default(now())
  site         Site     @relation(fields: [siteId], references: [id])
  deployment   Deployment @relation(fields: [deploymentId], references: [id])
}

// NextAuth
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
